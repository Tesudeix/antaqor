{
  "id": "gochu_brand_stylized_portrait_reference_matched_v2",
  "version": "2.0",
  "type": "style_transfer_image_generation",
  "engine_target": "nano_banana",
  "mode": "photo_to_stylized_3d_portrait",

  "critical_style_declaration": {
    "what_this_IS": "semi_stylized_3D_character_render_with_photoreal_elements",
    "what_this_is_NOT": [
      "cinematic_photography",
      "editorial_magazine_photo",
      "hyperreal_skin_portrait",
      "film_grain_aesthetic",
      "Vogue_style_editorial"
    ],
    "closest_references": [
      "3D_character_render_pixar_quality_but_more_realistic",
      "unreal_engine_metahuman_stylized_slightly_softened",
      "commercial_3D_avatar_render_premium_brand",
      "Genshin_Impact_character_portrait_meets_photoreal",
      "modern_mobile_game_cinematic_portrait"
    ],
    "render_engine_feel": "octane_or_unreal_with_soft_shader_pass"
  },

  "master_style_directive": {
    "primary": "(semi_stylized_3d_render:1.4)",
    "secondary": "(porcelain_airbrushed_skin:1.3)",
    "tertiary": "(soft_flat_studio_lighting:1.2)",
    "quaternary": "(slightly_enlarged_stylized_eyes:1.15)",
    "quinary": "(locked_frontal_crossed_arms_pose:1.25)",
    "overall": "identity_preserved_subject_rendered_as_semi_stylized_3d_brand_portrait_matching_reference_image_exactly"
  },

  "rendering_style_system": {
    "category": "semi_stylized_3D_portrait_render",
    "skin_render": {
      "finish": "smooth_porcelain_airbrushed",
      "pore_visibility": "none_or_minimal",
      "subsurface_scattering": "subtle_soft_warm_glow_under_skin",
      "highlight_placement": "soft_broad_highlights_on_cheekbones_nose_bridge_forehead",
      "shadow_quality": "gentle_soft_no_harsh_edges",
      "color_uniformity": "even_tone_slight_warmth_at_cheeks",
      "critical_note": "NOT_hyperreal_NOT_photographic_pores_this_is_stylized_smoothness"
    },
    "eye_render": {
      "size": "slightly_enlarged_from_real_proportions_stylized",
      "iris_detail": "clear_defined_iris_with_subtle_catchlights",
      "eyelash_render": "defined_but_not_hyperreal",
      "eye_shape_preservation": "preserve_reference_person_eye_SHAPE_but_render_in_stylized_manner",
      "pupil": "clear_dark_sharp",
      "tear_duct": "natural_soft"
    },
    "hair_render": {
      "strand_detail": "grouped_strands_not_individual_photoreal_hairs",
      "finish": "smooth_slightly_glossy_3d_render_look",
      "flyaways": "minimal_controlled",
      "color": "rich_deep_black_with_subtle_highlight"
    },
    "lip_render": {
      "finish": "soft_natural_matte_to_semi_matte",
      "texture": "smooth_stylized_not_photoreal_lip_lines",
      "color": "natural_warm_pink_with_subtle_gradient",
      "highlight": "soft_center_highlight"
    },
    "overall_render_quality": "premium_3d_brand_avatar_not_photograph"
  },

  "identity_preservation_system": {
    "priority_level": "maximum",
    "rule": "the_subject_must_be_recognizable_as_the_person_in_reference_photo_rendered_in_3D_stylized_form",
    "must_preserve": [
      "overall_face_shape_and_proportions",
      "eye_shape_and_spacing_rendered_slightly_larger",
      "nose_shape_and_bridge",
      "lip_shape",
      "jawline_and_chin_structure",
      "ethnicity_appearance",
      "approximate_age",
      "gender",
      "distinctive_moles_beauty_marks_freckles_keep_as_identity_markers",
      "eyebrow_shape_structure"
    ],
    "stylization_allowances": [
      "eyes_can_be_slightly_enlarged_stylized",
      "skin_smoothed_to_porcelain_finish",
      "minor_asymmetries_gently_balanced",
      "hair_restyled_to_brand_fixed_style",
      "proportions_subtly_idealized_not_dramatically"
    ],
    "never_change": [
      "fundamental_face_identity",
      "ethnicity",
      "gender",
      "distinctive_identity_moles_or_marks"
    ]
  },

  "locked_pose_system": {
    "pose_name": "frontal_crossed_arms_confident",
    "body_orientation": "directly_facing_camera_square_shoulders_zero_rotation",
    "arms": {
      "position": "crossed_horizontally_at_waist_to_lower_chest",
      "left_over_right": "left_forearm_rests_on_top_of_right_forearm",
      "hands_visible": "both_hands_resting_on_opposite_forearm"
    },
    "hands": {
      "finger_count_each_hand": "exactly_five_no_extra_no_missing",
      "finger_position": "relaxed_natural_slight_curve_fingers_separated_clearly",
      "thumb_visible": "yes_correctly_positioned",
      "nails": "clean_natural_short"
    },
    "head": {
      "angle": "level_straight_forward",
      "tilt": "zero_degrees",
      "chin": "slightly_lowered_confident"
    },
    "shoulders": "relaxed_square_even_height",
    "spine": "upright_natural_alignment"
  },

  "locked_expression_system": {
    "eyes": {
      "gaze": "direct_at_camera_lens",
      "intensity": "calm_confident_present",
      "openness": "relaxed_natural_not_wide_not_squinted"
    },
    "mouth": {
      "shape": "closed_softly_relaxed",
      "corners": "neutral_or_barely_perceptible_upturn",
      "no_smile_no_frown": true
    },
    "eyebrows": "relaxed_natural_neither_raised_nor_furrowed",
    "jaw": "relaxed_soft",
    "overall_read": "quiet_confident_professional_approachable"
  },

  "locked_wardrobe_system": {
    "top": {
      "type": "short_sleeve_polo_shirt",
      "color": "clean_off_white_cream",
      "fabric_render": "smooth_cotton_pique_stylized_fabric_render",
      "fit": "tailored_clean",
      "collar": "classic_polo_two_button_placket",
      "buttons": "natural_cream_bone_color"
    },
    "under_layer": {
      "type": "long_sleeve_black_base_layer",
      "visibility": "sleeves_extend_from_under_polo_to_wrists",
      "color": "deep_matte_black",
      "fabric_render": "smooth_performance_knit_stylized"
    },
    "gender_cut_adaptation": {
      "male": "slightly_looser_masculine_cut_same_garments",
      "female": "slightly_tailored_feminine_cut_same_garments"
    },
    "no_logos_no_accessories": true
  },

  "locked_hair_system": {
    "base_color": "preserve_reference_natural_color_usually_black_or_dark_brown",
    "female_style": {
      "primary": "sleek_center_part_pulled_back_into_clean_low_bun_or_low_ponytail",
      "finish": "smooth_3d_render_controlled_no_flyaways"
    },
    "male_style": {
      "primary": "short_clean_modern_cut_smooth_render",
      "finish": "matte_not_gelled_subtle_texture"
    }
  },

  "locked_lighting_system": {
    "setup": "soft_studio_flat_lighting_matching_reference",
    "key_light": {
      "type": "large_soft_frontal_diffused",
      "position": "camera_front_slightly_above",
      "color_temperature_k": 5200,
      "intensity": "bright_clean_even",
      "quality": "very_soft_almost_shadowless"
    },
    "fill_light": {
      "type": "soft_fill_opposite_side",
      "purpose": "eliminate_deep_shadows"
    },
    "rim_light": {
      "type": "minimal_optional",
      "intensity": "very_subtle_barely_visible"
    },
    "contrast_ratio": "very_low_2_to_1_flat_editorial",
    "shadow_behavior": "extremely_soft_shadows_almost_absent",
    "mood": "clean_bright_flat_commercial_3d_render_lighting",
    "NOT_THIS": [
      "cinematic_dramatic_lighting",
      "moody_directional_light",
      "rembrandt_or_split_lighting",
      "hard_shadows"
    ]
  },

  "locked_background_system": {
    "type": "solid_soft_gradient_backdrop",
    "color_options": {
      "primary": "warm_peach_to_cream_gradient_matching_reference_orange_tone",
      "alternative_a": "soft_off_white_to_pale_cream_gradient",
      "alternative_b": "warm_beige_gradient"
    },
    "texture": "completely_smooth_no_visible_texture",
    "clutter": "zero_pure_solid_color_field",
    "shadow_behind_subject": "very_subtle_soft_shadow_for_slight_grounding",
    "style_note": "this_is_studio_seamless_backdrop_3d_render_style"
  },

  "locked_camera_system": {
    "framing": "waist_up_portrait_with_crossed_arms_visible",
    "crop": "top_of_head_small_breathing_space_to_just_below_crossed_forearms",
    "angle_degrees": 0,
    "angle_direction": "level_eye_to_lens_straight_on",
    "lens_equivalent": "85mm_portrait_compression",
    "depth_of_field": "medium_subject_sharp_background_clean_solid",
    "subject_position": "centered_horizontally_symmetrical",
    "camera_distance": "medium_portrait_distance"
  },

  "locked_color_grading_system": {
    "overall_temperature": "neutral_warm",
    "white_balance": "5000k_to_5200k_clean",
    "highlights": "bright_soft_clean_not_blown",
    "midtones": "natural_warm_skin_protected_even",
    "shadows": "lifted_soft_not_crushed",
    "saturation": "natural_editorial_restrained_slight_warmth",
    "grading_style": "clean_premium_brand_3d_render_not_cinematic_film_grade",
    "film_grain": "none_this_is_digital_render_look",
    "reference_aesthetic": "premium_3d_character_portrait_brand_campaign"
  },

  "hand_anatomy_enforcement": {
    "priority": "maximum",
    "rules": [
      "exactly_five_fingers_per_hand",
      "natural_human_proportions",
      "fingers_clearly_separated_not_fused",
      "thumb_visible_and_correctly_positioned",
      "hands_resting_relaxed_on_opposite_forearm",
      "skin_tone_matches_face",
      "rendered_in_same_porcelain_stylized_smoothness_as_face"
    ]
  },

  "consistency_rules": {
    "every_output_must_have_identical": [
      "semi_stylized_3D_render_quality",
      "porcelain_airbrushed_skin_finish",
      "slightly_enlarged_stylized_eyes",
      "frontal_crossed_arms_pose",
      "neutral_confident_expression",
      "white_polo_black_base_layer",
      "soft_flat_studio_lighting",
      "warm_peach_cream_gradient_background",
      "waist_up_level_framing"
