    "step_6": "apply_flat_soft_studio_lighting_and_warm_gradient_background",
    "step_7": "verify_hand_anatomy_and_identity_recognition",
    "final_check": "result_should_look_like_premium_3D_character_render_not_photograph"
  },

  "output": {
