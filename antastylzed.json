    "cool_blue_ambient_lighting",
    "Vogue_magazine_editorial_aesthetic",
    "Blade_Runner_2049_cinematic_mood",
    "harsh_shadows",
    "outdoor_environment",
    "cluttered_background",
    "patterned_or_textured_backdrop",
    "dark_moody_atmosphere",
    "cartoon_anime_over_stylization",
    "photorealistic_portrait_photography",
